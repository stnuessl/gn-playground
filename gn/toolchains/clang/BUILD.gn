clang_toolchain("clang") {
  if (asm_launcher_clang != "") {
    asm_launcher = asm_launcher_clang
  }

  if (cc_launcher_clang != "") {
    cc_launcher = cc_launcher_clang
  }

  if (cxx_launcher_clang != "") {
    cxx_launcher = cxx_launcher_clang
  }

  append_cflags = [
    "-vfsoverlay",
    rebase_path(_vfs),
  ]

  asm = "clang"
  cc = "clang"
  cxx = "clang++"
  ar = "llvm-ar rcs"
  ld = "clang++"
  cp = "cp -f"
}
