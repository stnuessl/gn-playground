import("//gn/actions/python-action.gni")
import("//gn/toolchains/clang/vars.gni")
import("//gn/toolchains/decls/clang-toolchain.gni")

declare_args() {
  asm_launcher_clang = ""
  cc_launcher_clang = ""
  cxx_launcher_clang = ""
}

# Create memory mapping header stubs
_vfs_data = []

foreach(header, clang.memmaps) {
  _file = get_path_info(header, "file")

  _target = "$target_gen_dir/$_file"

  _vfs_data += [
    {
      source = rebase_path(header)
      target = rebase_path(_target)
    },
  ]

  _text = []
  _text = [
    "/*",
    " * Automatically generated file. Do not edit.",
    " * Source: " + rebase_path(header),
    " */",
    "",
    "#ifdef MEMMAP_ERROR",
    "#undef MEMMAP_ERROR",
    "#endif",
    "",
  ]

  write_file(_target, _text, "list lines")
}

# Write the virtual filesystem configuration to disk
_vfs_data_file = "$root_gen_dir/vfs-config.json"
_vfs = "$root_gen_dir/vfs.json"

write_file(_vfs_data_file, _vfs_data, "json")

# Create the virtual filesystem
_uv_script = "//gn/toolchains/clang/mkvfs.py"
_uv_args = [
  "run",
  rebase_path(_uv_script),
  "-o",
  rebase_path(_vfs),
  rebase_path(_vfs_data_file),
]
_uv_deps = [
    _uv_script,
    _vfs_data_file,
]

exec_script(uv_tool, _uv_args, "", _uv_deps)


